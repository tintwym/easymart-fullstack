# ---- APP CONFIG ----
APP_HOST=0.0.0.0
APP_PORT=8000
ENVIRONMENT=production

# ---- DATABASE CONFIG ----
POSTGRES_USER=prod_user
POSTGRES_PASSWORD=prod_password
POSTGRES_DB=easy_mart
POSTGRES_HOST=prod-db-host
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://prod_user:prod_password@prod-db-host:5432/easy_mart

# ---- AUTH / SECURITY ----
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200   # 30 days
