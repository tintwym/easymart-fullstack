# ---- APP CONFIG ----
APP_HOST=0.0.0.0
APP_PORT=8000
ENVIRONMENT=docker

# ---- DATABASE CONFIG ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=easy_mart
POSTGRES_HOST=postgres           # IMPORTANT: this matches docker-compose service name
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/easy_mart

# ---- AUTH / SECURITY ----
JWT_SECRET=dockersecretkey
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
